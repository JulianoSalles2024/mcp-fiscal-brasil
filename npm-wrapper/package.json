{
  "name": "mcp-fiscal-brasil",
  "version": "0.3.0",
  "description": "Node.js wrapper para o CLI Python mcp-fiscal-brasil. Consultas fiscais brasileiras (CNPJ, NFe, SPED) em JS/TS.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-fiscal": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "fiscal",
    "brasil",
    "cnpj",
    "nfe",
    "sped",
    "mcp",
    "tax"
  ],
  "author": "Nikolas de Hor",
  "license": "MIT",
  "homepage": "https://github.com/DeHor-Labs/mcp-fiscal-brasil",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeHor-Labs/mcp-fiscal-brasil.git",
    "directory": "npm-wrapper"
  },
  "bugs": {
    "url": "https://github.com/DeHor-Labs/mcp-fiscal-brasil/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
